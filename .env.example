# WeddingEase — Environment Variables
# Copy this to .env.local and fill in real values
# NEVER commit .env.local to version control

# Firebase
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=wedding-ease-dc99a.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=wedding-ease-dc99a
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=wedding-ease-dc99a.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# Google Sign-In (web client ID from Firebase Console)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=

# Backend API
EXPO_PUBLIC_BACKEND_URL=http://localhost:3000/api/v1

# Razorpay (key_id only — key_secret stays on server)
EXPO_PUBLIC_RAZORPAY_KEY_ID=
